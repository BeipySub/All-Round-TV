# Application
APP_ENV=development
APP_DEBUG=false
APP_BASE_URL=http://localhost:8080

# Initial administrator; replace before first startup
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-before-startup

# PostgreSQL
POSTGRES_DB=allroundtv
POSTGRES_USER=allroundtv
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://allroundtv:change-me@postgres:5432/allroundtv

# Redis
REDIS_URL=redis://redis:6379/0

# Session and CSRF; generate independent random values
SESSION_SECRET=change-me
CSRF_SECRET=change-me

# Providers
TMDB_API_KEY=

# Logging
LOG_LEVEL=INFO
